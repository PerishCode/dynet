{
  "log": {
    "level": "info"
  },
  "inbounds": [
    {
      "tag": "tcp-in",
      "type": "tcp",
      "metadata": {
        "purpose": "model-fixture"
      },
      "payload": {
        "listen": "127.0.0.1",
        "listenPort": 1080
      }
    },
    {
      "tag": "udp-in",
      "type": "udp",
      "payload": {
        "listen": "127.0.0.1",
        "listenPort": 1053
      }
    }
  ],
  "outbounds": [
    {
      "tag": "tcp-out",
      "type": "tcp",
      "payload": {
        "server": "example.com",
        "serverPort": 443
      }
    },
    {
      "tag": "udp-out",
      "type": "udp",
      "payload": {
        "server": "1.1.1.1",
        "serverPort": 53
      }
    }
  ],
  "routes": [
    {
      "inbound": "tcp-in",
      "outbound": "tcp-out"
    },
    {
      "inbound": "udp-in",
      "outbound": "udp-out"
    }
  ]
}
